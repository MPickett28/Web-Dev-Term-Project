{
  "name": "terraria-arsenal",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.18.1",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "concurrently --kill-others --names CLIENT,API \"npm run client\" \"npm run server\"",
    "dev": "npm start",
    "client": "react-scripts start",
    "server": "npm --prefix server run dev",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
